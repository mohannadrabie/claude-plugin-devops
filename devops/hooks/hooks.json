{
  "hooks": {
    "SessionStart": [
      { "hooks": [{ "type": "command", "command": "node -e \"try{require('node:fs').accessSync('docs/adr-cache.mjs');require('node:child_process').execFileSync(process.execPath,['docs/adr-cache.mjs','--ensure'],{stdio:'inherit',timeout:10000})}catch(e){}\"", "timeout": 15 }] }
    ],
    "PreToolUse": [
      { "matcher": "Bash", "hooks": [{ "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/guard.mjs\"" }] },
      { "matcher": "Edit|Write|MultiEdit|NotebookEdit", "hooks": [{ "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/guard.mjs\"" }] }
    ],
    "TaskCreated": [
      { "hooks": [{ "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/team-gate.mjs\" TaskCreated" }] }
    ],
    "TaskCompleted": [
      { "hooks": [{ "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/team-gate.mjs\" TaskCompleted" }] }
    ],
    "TeammateIdle": [
      { "hooks": [{ "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/team-gate.mjs\" TeammateIdle" }] }
    ]
  }
}
